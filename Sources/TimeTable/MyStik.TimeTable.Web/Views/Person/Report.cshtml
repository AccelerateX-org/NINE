@model MyStik.TimeTable.Web.Models.PersonViewModel
@{
    ViewBag.Title = "Visitenkarte";

    var member = Model.Members.FirstOrDefault();
}

<div class="row">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid"></i></a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Campus", "University")">HM</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Card", "Person", new {memberId = member.Id})">@Model.FullName</a></li>
            <li class="breadcrumb-item active" aria-current="page">
                <div class="btn-group">
                    @if (ViewBag.PrevSemester != null)
                    {
                        <a href="@Url.Action("Card", "Person", new {memberId = member.Id, semId=ViewBag.PrevSemester.Id})"><i class="bi bi-chevron-double-left"></i></a>
                    }
                    else
                    {
                        <a class="disabled" href="#"><i class="bi bi-chevron-double-left"></i></a>
                    }
                    <span class="ms-2 me-2">@ViewBag.CurrentSemester.Name</span>
                    @if (ViewBag.NextSemester != null)
                    {
                        <a href="@Url.Action("Card", "Person", new {memberId = member.Id, semId=ViewBag.NextSemester.Id})"><i class="bi bi-chevron-double-right"></i></a>
                    }
                    else
                    {
                        <a class="disabled" href="#"><i class="bi bi-chevron-double-right"></i></a>
                    }
                </div>
            </li>
        </ol>
    </nav>
</div>
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Lehrverwendungsnachweis | Abschnitt Lehrveranstaltungen</h5>
                <table class="table table-sm">
                    <thead>
                    <tr>
                        <th>FK</th>
                        <th>Code</th>
                        <th>Titel</th>
                        <th>Modul</th>
                        <th>Fach</th>
                        <th>SWS</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var course in Model.Courses)
                    {
                        foreach (var teaching in course.SubjectTeachings)
                        {
                            <tr>
                                <td>@course.Organiser.ShortName</td>
                                <td>@course.ShortName</td>
                                <td>@course.Name</td>
                                <td>@teaching.Subject.Module.Name</td>
                                <td>@teaching.Subject.FullName</td>
                                <td>@teaching.Subject.SWS</td>
                            </tr>
                        }
                    }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

