
@using System.Data.Entity
@using System.Web.Services.Protocols
@using MyStik.TimeTable.Data
@using MyStik.TimeTable.Web.Helpers
@model MyStik.TimeTable.Web.Models.SemesterViewModel

@{
    ViewBag.Title = "Semesterplanung";

    var db = new TimeTableDbContext();
    var nCourses = db.Activities.OfType<Course>().Count(x => x.Organiser.Id == Model.Organiser.Id && x.Semester.Id == Model.Semester.Id);
    var nProjected = db.Activities.OfType<Course>().Count(x => x.Organiser.Id == Model.Organiser.Id && x.Semester.Id == Model.Semester.Id && x.IsProjected);
    var nInternal = db.Activities.OfType<Course>().Count(x => x.Organiser.Id == Model.Organiser.Id && x.Semester.Id == Model.Semester.Id && x.IsInternal);
    var nLocked = db.Activities.OfType<Course>().Count(x => x.Organiser.Id == Model.Organiser.Id && x.Semester.Id == Model.Semester.Id && !x.Occurrence.IsAvailable);


    var segments = db.SemesterDates.Where(x => x.Organiser != null && x.Organiser.Id == Model.Organiser.Id && x.Semester.Id == Model.Semester.Id).ToList();

    var curricula = db.Curricula.Where(x => x.Organiser.Id == Model.Organiser.Id && !x.IsDeprecated).ToList();

    var sources = db.Activities.OfType<Course>().Where(x => x.Organiser.Id == Model.Organiser.Id && x.Semester.Id == Model.Semester.Id).Select(x => x.ExternalSource).Distinct().ToList();
}


<div class="row">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")"><i class="bi bi-grid"></i></a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Campus", "University")">HM</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Faculty", "University", new {id=Model.Organiser.Id})">@Model.Organiser.ShortName</a></li>
                <li class="breadcrumb-item active" aria-current="page">
                    <div class="btn-group">
                        @if (ViewBag.PrevSemester != null)
                        {
                            <a href="@Url.Action("Details", "Semester", new {semId=ViewBag.PrevSemester.Id, orgId=Model.Organiser.Id})"><i class="bi bi-chevron-double-left"></i></a>
                        }
                        else
                        {
                            <a class="disabled" href="#"><i class="bi bi-chevron-double-left"></i></a>
                        }
                        <span class="ms-2 me-2">Semesterplanung @ViewBag.CurrentSemester.Name</span>
                        @if (ViewBag.NextSemester != null)
                        {
                            <a href="@Url.Action("Details", "Semester", new {semId=ViewBag.NextSemester.Id, orgId=Model.Organiser.Id})"><i class="bi bi-chevron-double-right"></i></a>
                        }
                        else
                        {
                            <a class="disabled" href="#"><i class="bi bi-chevron-double-right"></i></a>
                        }
                    </div>
                </li>
            </ol>
        </nav>
    </div>
</div>

@if (ViewBag.UserRight.IsCourseAdmin)
{
    <div class="row">
        <div class="col-2">
            <nav aria-label="Seitenmenü">
                <div class="card mb-3">
                    <div class="list-group">
                        <div class="list-group-item list-group-item-secondary">Planungsgrundlagen</div>
                        <a href="@Url.Action("Segments", "Semester", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Abschnitte"><i class="bi bi-calendar-check"></i><span class="d-none d-sm-inline"> Zeitpläne</span></a>
                        <a href="@Url.Action("Organiser", "StudyPlan", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Studienpläne"><i class="bi bi-folder-check"></i><span class="d-none d-sm-inline"> Studienpläne</span></a>
                        <a href="@Url.Action("Lecturer", "Semester", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Studienpläne"><i class="bi bi-journal-check"></i><span class="d-none d-sm-inline"> Einsatzpläne (LVN)</span></a>
                        <a href="@Url.Action("Cohorts", "Semester", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Studienpläne"><i class="bi bi-bookmark-check"></i><span class="d-none d-sm-inline"> Kapazitätspläne (CNW)</span></a>
                    </div>
                </div>
                <div class="card mb-3">
                    <div class="list-group">
                        <div class="list-group-item list-group-item-secondary">Lehrveranstaltungen</div>
                        <a href="@Url.Action("Courses", "Semester", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Lehrplan"><i class="bi bi-easel"></i><span class="d-none d-sm-inline"> Lehrplan</span></a>
                        <a href="@Url.Action("Forward", "Semester", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Fortschreibung"><i class="bi bi-repeat"></i><span class="d-none d-sm-inline"> Fortschreibung</span></a>
                        <a href="@Url.Action("Index", "Import", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Import"><i class="bi bi-upload"></i><span class="d-none d-sm-inline"> Import</span></a>
                        <a href="@Url.Action("Conflicts", "Semester", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Konfliktbehebung"><i class="bi bi-lightning"></i><span class="d-none d-sm-inline"> Konfliktbehebung</span></a>
                    </div>
                </div>
                <div class="card mb-3">
                    <div class="list-group">
                        <div class="list-group-item list-group-item-secondary">Prüfungen</div>
                        <a href="@Url.Action("Index", "Exam", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Abschnitte"><i class="bi bi-trophy"></i><span class="d-none d-sm-inline"> Prüfungsplan</span></a>
                        <a href="@Url.Action("Dates", "Exam", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Studienpläne"><i class="bi bi-calendar-event"></i><span class="d-none d-sm-inline"> Termine</span></a>
                        <a href="@Url.Action("Observer", "Exam", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Studienpläne"><i class="bi bi-person-walking"></i><span class="d-none d-sm-inline"> Aufsichten</span></a>
                        <a href="@Url.Action("Students", "Exam", new {semId=Model.Semester.Id, orgId=Model.Organiser.Id})" class="list-group-item list-group-item-action" aria-label="Studienpläne"><i class="bi bi-person-badge"></i><span class="d-none d-sm-inline"> Studierende</span></a>
                    </div>
                </div>
            </nav>
        </div>
        <div class="col-10">
            <div class="row mb-3">
                <div class="col-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-clock"></i> Rahmenbedingungen</h5>
                            <div class="row">
                                <div class="col-12">Zeitpläne</div>
                            </div>
                            <div class="row">
                                <div class="col-4">Semester</div>
                                <div class="col-7">@Model.Semester.StartCourses.ToString("d") - @Model.Semester.EndCourses.ToString("d")</div>
                                <div class="col-1"><i class="bi bi-check text-success"></i></div>
                            </div>
                            @foreach (var segment in segments)
                            {
                                <div class="row">
                                    <div class="col-4">@segment.Description</div>
                                    <div class="col-7">@segment.From.ToString("d") - @segment.To.ToString("d")</div>
                                    <div class="col-1"><i class="bi bi-check text-success"></i></div>
                                </div>
                            }
                            <div class="row mt-3">
                                <div class="col-12">Status</div>
                            </div>
                            <div class="row">
                                <div class="col-4">Studienpläne</div>
                                <div class="col-7">3 von 7</div>
                                <div class="col-1"><i class="bi bi-check text-success"></i></div>
                            </div>
                            <div class="row">
                                <div class="col-4">Verfügbarkeiten</div>
                                <div class="col-7">12 von 48</div>
                                <div class="col-1"><i class="bi bi-check text-success"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-tv"></i> Lehrveranstaltungen</h5>
                            <div class="row">
                                <div class="col-12">Aufkommen</div>
                            </div>
                            <div class="row">
                                <div class="col-7">Anzahl gesamt</div>
                                <div class="col-4">@nCourses</div>
                                <div class="col-1"><i class="bi bi-check text-success"></i></div>
                            </div>
                            @foreach (var source in sources)
                            {
                                var n = db.Activities.OfType<Course>().Count(x => x.Organiser.Id == Model.Organiser.Id && x.Semester.Id == Model.Semester.Id && x.ExternalSource == source);
                                var s = string.IsNullOrEmpty(source) ? "manuell" : source;
                                <div class="row">
                                    <div class="col-7">@s</div>
                                    <div class="col-4">@n</div>
                                    <div class="col-1"><i class="bi bi-check text-success"></i></div>
                                </div>
                            }
                            <div class="row mt-3">
                                <div class="col-12">Status</div>
                            </div>
                            <div class="row">
                                <div class="col-7">Im Planungsmodus</div>
                                <div class="col-2">@nProjected</div>
                                <div class="col-3">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-success" href="@Url.Action("Lock", new { orgId = Model.Organiser.Id, semId = Model.Semester.Id, state = 2 })"><i class="bi bi-check-circle"></i></a>
                                        <a class="btn btn-outline-danger" href="@Url.Action("Lock", new { orgId = Model.Organiser.Id, semId = Model.Semester.Id, state = 1 })"><i class="bi bi-ban"></i></a>
                                        <a class="btn btn-outline-secondary"><i class="bi bi-info-circle"></i></a>
                                    </div>
                                </div>
                            </div>
                            <div class="row mt-1">
                                <div class="col-7">Für Lehrende gesperrt</div>
                                <div class="col-2">@nInternal</div>
                                <div class="col-3">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-success" href="@Url.Action("Lock", new { orgId = Model.Organiser.Id, semId = Model.Semester.Id, state = 4 })"><i class="bi bi-unlock"></i></a>
                                        <a class="btn btn-outline-danger" href="@Url.Action("Lock", new { orgId = Model.Organiser.Id, semId = Model.Semester.Id, state = 3 })"><i class="bi bi-lock"></i></a>
                                        <a class="btn btn-outline-secondary"><i class="bi bi-info-circle"></i></a>
                                    </div>
                                </div>
                            </div>
                            <div class="row mt-1">
                                <div class="col-7">Für Studierende geschlossen</div>
                                <div class="col-2">@nLocked</div>
                                <div class="col-3">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-success" href="@Url.Action("Lock", new { orgId = Model.Organiser.Id, semId = Model.Semester.Id, state = 6 })"><i class="bi bi-door-open"></i></a>
                                        <a class="btn btn-outline-danger" href="@Url.Action("Lock", new { orgId = Model.Organiser.Id, semId = Model.Semester.Id, state = 5 })"><i class="bi bi-door-closed"></i></a>
                                        <a class="btn btn-outline-secondary"><i class="bi bi-info-circle"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-binoculars"></i> Prüfungen</h5>
                            <div class="row">
                                <div class="col-12">Aufkommen</div>
                            </div>
                            <div class="row">
                                <div class="col-7">Anzahl gesamt</div>
                                <div class="col-4">#N/A</div>
                                <div class="col-1"><i class="bi bi-check text-success"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
