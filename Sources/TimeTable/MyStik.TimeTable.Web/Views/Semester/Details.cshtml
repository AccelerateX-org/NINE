        </div>
    </div>

}
else
{
    <div class="row">
        <div class="col-md-12">
            <div class="alert alert-danger">
                <h5>Zugang nur für Admins auf Ebene Lehrveranstaltungen</h5>
            </div>
        </div>
    </div>
}
